{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "tada": {
      "command": "python3",
      "args": [
        "${TADA_HOME}/mcp_server.py",
        "--url", "https://tada-board.fly.dev",
        "--project", "dyno"
      ]
    }
  }
}
